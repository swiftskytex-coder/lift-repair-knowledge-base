# OpenRouter API Configuration
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_api_key_here

# Модель по умолчанию
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Опционально: HTTP Referer для OpenRouter
OPENROUTER_HTTP_REFERER=https://github.com/swiftskytex-coder/lift-repair-knowledge-base

# Опционально: Название приложения
OPENROUTER_APP_NAME=LiftRepairKnowledgeBase
